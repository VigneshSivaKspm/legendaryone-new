# Google Business Reviews (Leadership page)
# Get your API key from: https://cloud.google.com/docs/authentication/api-keys
VITE_GOOGLE_API_KEY=

# Your Google Business Place ID
# Find it here: https://developers.google.com/maps/documentation/places/web-service/overview
VITE_GOOGLE_PLACE_ID=

# Gmail Configuration (for contact form emails)
# Follow EMAIL_SETUP.md to get these values
# 1. Enable 2FA on your Gmail account
# 2. Generate an App Password from https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email to receive contact form submissions
CONTACT_EMAIL=your-email@gmail.com
