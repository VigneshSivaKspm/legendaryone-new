  "devCommand": "npm run dev",
  "outputDirectory": "dist",
  "env": {
    "GMAIL_USER": {
      "description": "Gmail account for sending emails"
    },
    "GMAIL_APP_PASSWORD": {
      "description": "Gmail app-specific password"
